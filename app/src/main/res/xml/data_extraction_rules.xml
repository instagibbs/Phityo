<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Used for Android 12+ (API 31). -->
    <cloud-backup>
        <include domain="database" path="phityo.db" />
        <include domain="database" path="phityo.db-shm" />
        <include domain="database" path="phityo.db-wal" />
        <include domain="file" path="datastore/phityo_settings.preferences_pb" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="phityo.db" />
        <include domain="database" path="phityo.db-shm" />
        <include domain="database" path="phityo.db-wal" />
        <include domain="file" path="datastore/phityo_settings.preferences_pb" />
    </device-transfer>
</data-extraction-rules>
